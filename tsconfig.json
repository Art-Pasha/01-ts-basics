{
"compilerOptions": {
  "target": "es2023",
  "module": "commonjs",
  "esModuleInterop": true,
  "strict": true,
  "outDir": "./dist",
  "rootDir": "./src",

/* Bundler mode */
"moduleResolution": "bundler",
  "allowImportingTsExtensions": true,
  "verbatimModuleSyntax": true,
  "moduleDetection": "force",
  "noEmit": true,

/* Linting */
"noUnusedLocals": true,
  "noUnusedParameters": true,
  "erasableSyntaxOnly": true,
  "noFallthroughCasesInSwitch": true
},
  "include": ["src"]
}
